class Alumno:

    def __init__(self, nombre, nota):
        self.nombre = nombre
        self.nota = nota

    def imprimir(self):
        print("Nombre:", self.nombre)
        print("Nota:", self.nota)

    def resultado(self):
        if self.nota >= 6:
            print("Aprobado")
        else:
            print("Desaprobado")


# Programa principal
alumno1 = Alumno("Hernesto", 7)
alumno1.imprimir()
alumno1.resultado()